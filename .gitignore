# ── Frappe Bench ─────────────────────────────────────────────────────────────
env/
logs/
config/
sites/*/private/
sites/*/public/files/
sites/*/public/private/
sites/*/error-snapshots/
sites/*/locks/
sites/*/task-logs/
sites/*/archived_sites/
sites/*/backups/
sites/*/site_config.json
sites/currentsite.txt
sites/common_site_config.json
sites/.site-name

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
.Python
pip-log.txt
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
apps/*/frontend/node_modules/
apps/*/frontend/dist/
yarn.lock
package-lock.json
.yarn/
.pnp.*
.npm/

# ── Vite / Build output ───────────────────────────────────────────────────────
apps/*/public/frontend/
apps/*/www/*.html
!apps/*/www/*.py

# ── Frappe App artifacts ──────────────────────────────────────────────────────
apps/*/.git
apps/*/dist/
apps/*/*.egg-info/
apps/*/node_modules/

# ── Generated assets (bench build) ───────────────────────────────────────────
assets/

# ── IDEs & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
secrets/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ── Celery / Redis ────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Supervisor / Nginx configs (generated by bench) ──────────────────────────
config/supervisor.conf
config/nginx.conf
config/redis_cache.conf
config/redis_queue.conf
config/redis_socketio.conf

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.pid
*.bak
*.tmp
*.orig
.cache/
tmp/



# ── Frappe App artifacts ──────────────────────────────────────────────────────
# This ignores the .git folders, but see the "Pro Tip" below to fully fix this
apps/*/.git
apps/*/dist/
apps/*/*.egg-info/
apps/*/node_modules/

# ── Git Configuration ─────────────────────────────────────────────────────────
# Force consistent line endings for specific text files that caused warnings
Procfile text eol=lf
*.txt text eol=lf
*.json text eol=lf

# ── Project Specifics ─────────────────────────────────────────────────────────
# Ensure these specific app directories don't cause ghosting issues
apps/crm/
apps/crm_chat_override/
apps/frappe/